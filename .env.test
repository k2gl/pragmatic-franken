# Test overrides. DATABASE_URL is inherited from .env / the real environment
# (PostgreSQL in both the dev container and CI); Doctrine appends the "_test"
# suffix to the database name — see when@test in config/packages/doctrine.yaml.
# `make test` creates and migrates that database automatically.
APP_SECRET=test-secret
MERCURE_URL=http://localhost/.well-known/mercure
MERCURE_PUBLIC_URL=http://localhost/.well-known/mercure
MERCURE_JWT_SECRET=test-secret
