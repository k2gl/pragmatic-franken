{
    "name": "k2gl/pragmatic-franken",
    "description": "Pragmatic Symfony skeleton on FrankenPHP: Vertical Slices + CQRS over Messenger, worker mode, agent-ready docs",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "skeleton",
        "template",
        "boilerplate",
        "starter-kit",
        "symfony",
        "frankenphp",
        "cqrs",
        "vertical-slice",
        "agents-md"
    ],
    "homepage": "https://github.com/k2gl/pragmatic-franken",
    "require": {
        "php": ">=8.5",
        "ext-pdo_pgsql": "*",
        "doctrine/dbal": "^4.0",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/migrations": "^3.8",
        "doctrine/orm": "^3.3",
        "k2gl/app-env": "^1.0",
        "k2gl/entity-exist": "^1.14",
        "k2gl/enum": "^2.1",
        "k2gl/sigstore-verify": "^1.2",
        "k2gl/slsa-provenance": "^1.1",
        "nelmio/api-doc-bundle": "^5.9",
        "nelmio/cors-bundle": "^2.6",
        "predis/predis": "^3.3",
        "symfony/asset": "^8.0",
        "symfony/asset-mapper": "^8.0",
        "symfony/console": "^8.0",
        "symfony/doctrine-bridge": "^8.0",
        "symfony/doctrine-messenger": "^8.1",
        "symfony/dotenv": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/http-kernel": "^8.0",
        "symfony/mercure-bundle": "^0.4.2",
        "symfony/messenger": "^8.0",
        "symfony/monolog-bridge": "^8.0",
        "symfony/property-access": "^8.0",
        "symfony/property-info": "^8.0",
        "symfony/routing": "^8.0",
        "symfony/runtime": "^8.0",
        "symfony/security-bundle": "^8.0",
        "symfony/serializer": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "symfony/uid": "^8.0",
        "symfony/validator": "^8.0",
        "symfony/var-exporter": "^8.0"
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.2",
        "fakerphp/faker": "^1.24",
        "k2gl/array-reader": "^2.1",
        "k2gl/phpunit-fluent-assertions": "^12.4",
        "laravel/pint": "^1.29",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0",
        "symfony/maker-bundle": "^1.67",
        "symfony/phpunit-bridge": "^8.0",
        "zenstruck/browser": "^1.6",
        "zenstruck/foundry": "^2.0",
        "zenstruck/messenger-test": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "pint --test",
        "fix": "pint",
        "analyze": "phpstan analyze --level=10",
        "check": [
            "@lint",
            "@analyze"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "extra": {
        "symfony": {
            "allow-contrib": true
        }
    }
}
