# Caddy/FrankenPHP configuration. Baked into all image stages and bind-mounted
# over /etc/caddy/Caddyfile in dev (see docker-compose.yml), so edits apply on
# container restart without a rebuild.
#
# Worker mode comes from the FRANKENPHP_CONFIG env var ("worker ./public/index.php");
# symfony/runtime 8 drives the worker loop natively.
{
	{$CADDY_GLOBAL_OPTIONS}

	frankenphp {
		{$FRANKENPHP_CONFIG}
	}
}

{$CADDY_EXTRA_CONFIG}

{$SERVER_NAME:localhost} {
	log {
		format json
	}

	root * public/
	encode zstd br gzip

	# FrankenPHP's built-in Mercure hub lives on the private :3000 site below.
	# Browsers subscribe through this site — same origin, no mixed content.
	handle /.well-known/mercure* {
		reverse_proxy localhost:3000
	}

	{$CADDY_SERVER_EXTRA_DIRECTIVES}

	php_server
}

# Private Mercure hub (not published by docker-compose). PHP publishes here over
# plain HTTP (MERCURE_URL), avoiding TLS and Host-matching pitfalls in-container.
http://:3000 {
	mercure {
		transport_url {$MERCURE_TRANSPORT_URL:bolt:///data/mercure.db}
		publisher_jwt {env.MERCURE_JWT_SECRET}
		subscriber_jwt {env.MERCURE_JWT_SECRET}
		anonymous
		subscriptions
	}

	respond "Not Found" 404
}
